# MetaHarmonizer — environment configuration.
# Copy to .env and adjust:   cp .env.example .env
# .env is git-ignored. This file is the canonical catalogue (spec §6.5).
# Required vars are marked [REQUIRED]; the app fails to boot if they're missing
# (enforced from Sprint 2 once app/core/settings.py lands).

# ── Engine ────────────────────────────────────────────────────────────────
ENGINE_IMPL=metaharmonizer            # metaharmonizer | mock (tests/CI)
# METHOD_MODEL_YAML=                   # override engine model registry (optional)
# LLM_THRESHOLD=0.5                    # Stage-4 LLM gate
# GEMINI_API_KEY=                      # unset -> engine runs in manual mode (no LLM)
# UMLS_API_KEY=                        # needed once for first-run ontology KB build

# ── Datastore / cache ───────────────────────────────────────────────────────
# Docker path: compose overrides these with container DSNs (postgres:5432 / redis:6379).
# No-Docker dev path (scripts/dev_services.ps1): portable PG on :5433, Redis on :6380 —
#   DATABASE_URL=postgresql+asyncpg://mh:mh_dev_password@127.0.0.1:5433/metaharmonizer
#   REDIS_URL=redis://127.0.0.1:6380/0
POSTGRES_USER=mh
POSTGRES_PASSWORD=mh_dev_password
POSTGRES_DB=metaharmonizer
DATABASE_URL=postgresql+asyncpg://mh:mh_dev_password@localhost:5432/metaharmonizer   # [REQUIRED from S2]
REDIS_URL=redis://localhost:6379/0

# ── Job pipeline (Sprint 4) ──────────────────────────────────────────
JOB_MODE=inline            # inline (dev, just uvicorn) | queue (prod, arq workers)
JOB_SOFT_TIMEOUT_SEC=300
JOB_HARD_TIMEOUT_SEC=900
JOB_MAX_ATTEMPTS=3
WS_TICKET_TTL_SEC=30                                                   # [REQUIRED from S4]

# ── Object storage ──────────────────────────────────────────────────────────
OBJECT_STORE_URL=file:///app/data/objects   # file://… self-host | s3://… hosted (R2)
# R2_BUCKET=
# R2_KEY=
# R2_SECRET=

# ── Auth / security (Sprint 3) ──────────────────────────────────────────────
AUTH_MODE=jwt                          # jwt | none (self-host internal-network only)
JWT_SECRET=change-me-in-prod-min-32-bytes-long-string   # [REQUIRED] boot fails if <32 bytes
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=30
ALLOWED_EMAIL_DOMAINS=                 # comma-separated allow-list; empty -> admin-invite-only
COOKIE_SECURE=false                    # set true in prod (HTTPS) so the refresh cookie is Secure-only
LOGIN_MAX_FAILURES=5                   # lock the account after N consecutive failed logins
LOGIN_LOCKOUT_MIN=15                   # lockout window in minutes
HIBP_CHECK=true                        # reject breached passwords on signup (fail-open on network error)
# RESEND_API_KEY=                      # unset -> email verification disabled

# ── Web / CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8080   # [REQUIRED] no wildcards in prod

# ── Upload safety (spec §6.4) ─────────────────────────────────────────────────
MAX_UPLOAD_MB=50          # byte-size guard only; no row/column ceilings

# ── Data retention (spec §6.8) ────────────────────────────────────────────────
RETENTION_UPLOADS_DAYS=90
RETENTION_EXPORTS_DAYS=30
RETENTION_REVOKED_SESSIONS_DAYS=90

# ── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info                         # debug | info | warning
# SENTRY_DSN=                          # unset -> stderr structured logs only
