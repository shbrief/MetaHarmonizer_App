# ── Public-facing MetaHarmonizerApp profile ──────────────────────────────────
# Same image as the cBioPortal/internal instance; this profile just tightens the
# limits so a public demo can't be used as a bulk service. Copy to `.env` on the
# public host and fill the [REQUIRED] secrets. See `.env.example` for the full
# catalogue and field-by-field comments.
#
# Two-deployment model (Sehyun's Q8): run one instance for cBioPortal/internal
# curation (generous limits) and a second public-facing one with the caps below.
# Nothing in the code differs — only these env values.

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mh:CHANGE_ME@db:5432/metaharmonizer   # [REQUIRED]
REDIS_URL=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Keep JWT on for a public instance (AUTH_MODE=none has NO auth and is only for a
# trusted internal network). Restrict who can self-register via email domains, or
# leave empty for admin-invite-only.
AUTH_MODE=jwt
JWT_SECRET=CHANGE_ME_AT_LEAST_32_BYTES_LONG_RANDOM        # [REQUIRED]
COOKIE_SECURE=true
ALLOWED_EMAIL_DOMAINS=                                     # empty = invite-only

# ── Upload caps (the point of this profile) ───────────────────────────────────
MAX_UPLOAD_MB=5           # small byte ceiling for a public demo
MAX_UPLOAD_ROWS=2000      # row ceiling so it stays a demo, not a bulk pipeline

# ── Rate limiting (tighter than internal) ─────────────────────────────────────
RATE_LIMIT_AUTH=120       # per identity per window
RATE_LIMIT_ANON=10
RATE_LIMIT_WINDOW_SEC=60

# ── Web / CORS ────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://demo.example.org                     # [REQUIRED] no wildcards
APP_BASE_URL=https://demo.example.org

# ── Engine (optional) ─────────────────────────────────────────────────────────
# A public instance can run the deterministic dictionary path (cheap, no keys).
# Turn the ontology engine on only if you have a pre-built KB + UMLS key.
ONTOLOGY_ENGINE=0
